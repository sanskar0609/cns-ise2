# ─── Server ───────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────
# Set this to your deployed Vercel frontend URL
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ─── Rate Limiting ────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
